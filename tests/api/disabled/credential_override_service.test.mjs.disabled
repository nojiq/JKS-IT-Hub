import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import { 
  previewCredentialOverride, 
  confirmCredentialOverride,
  DisabledUserError 
} from '../../../apps/api/src/features/credentials/service.js';
import * as repo from '../../../apps/api/src/features/credentials/repo.js';

// Mock the repo module
vi.mock('../../../apps/api/src/features/credentials/repo.js');

describe('Credential Override Service', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe('previewCredentialOverride', () => {
    it('should throw error when user does not exist', async () => {
      repo.getUserById.mockResolvedValue(null);

      await expect(
        previewCredentialOverride('non-existent-id', 'email', { 
          username: 'test@example.com',
          reason: 'Test reason' 
        })
      ).rejects.toThrow('User not found');
    });

    it('should throw DisabledUserError when user is disabled', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        username: 'testuser',
        status: 'disabled'
      });

      await expect(
        previewCredentialOverride('user-1', 'email', { 
          username: 'test@example.com',
          reason: 'Test reason' 
        })
      ).rejects.toThrow(DisabledUserError);
    });

    it('should throw error when no active credential exists', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        username: 'testuser',
        status: 'active'
      });
      repo.getUserCredentialBySystem.mockResolvedValue(null);

      await expect(
        previewCredentialOverride('user-1', 'email', { 
          username: 'test@example.com',
          reason: 'Test reason' 
        })
      ).rejects.toThrow('No active credential for system');
    });

    it('should generate preview for username override only', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        username: 'testuser',
        status: 'active'
      });
      repo.getUserCredentialBySystem.mockResolvedValue({
        id: 'cred-1',
        userId: 'user-1',
        system: 'email',
        username: 'old.user@company.com',
        password: 'OldPassword123',
        templateVersion: 1
      });
      repo.storePreviewSession.mockResolvedValue('override_preview_token_123');

      const result = await previewCredentialOverride('user-1', 'email', {
        username: 'new.user@company.com',
        reason: 'User requested specific username format'
      });

      expect(result).toHaveProperty('previewToken');
      expect(result.currentCredential.username).toBe('old.user@company.com');
      expect(result.proposedCredential.username).toBe('new.user@company.com');
      expect(result.changes.usernameChanged).toBe(true);
      expect(result.changes.passwordChanged).toBe(false);
      expect(result.reason).toBe('User requested specific username format');
    });

    it('should generate preview for password override only', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        username: 'testuser',
        status: 'active'
      });
      repo.getUserCredentialBySystem.mockResolvedValue({
        id: 'cred-1',
        userId: 'user-1',
        system: 'email',
        username: 'user@company.com',
        password: 'OldPassword123',
        templateVersion: 1
      });
      repo.storePreviewSession.mockResolvedValue('override_preview_token_456');

      const result = await previewCredentialOverride('user-1', 'email', {
        password: 'NewPassword456!',
        reason: 'Security policy requires password change'
      });

      expect(result.changes.usernameChanged).toBe(false);
      expect(result.changes.passwordChanged).toBe(true);
      expect(result.proposedCredential.username).toBe('user@company.com');
      expect(result.proposedCredential.password).toBe('NewPassword456!');
    });

    it('should generate preview for both username and password override', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        username: 'testuser',
        status: 'active'
      });
      repo.getUserCredentialBySystem.mockResolvedValue({
        id: 'cred-1',
        userId: 'user-1',
        system: 'email',
        username: 'old.user@company.com',
        password: 'OldPassword123',
        templateVersion: 1
      });
      repo.storePreviewSession.mockResolvedValue('override_preview_token_789');

      const result = await previewCredentialOverride('user-1', 'email', {
        username: 'new.user@company.com',
        password: 'NewPassword456!',
        reason: 'Complete credential reset requested by user'
      });

      expect(result.changes.usernameChanged).toBe(true);
      expect(result.changes.passwordChanged).toBe(true);
    });
  });

  describe('confirmCredentialOverride', () => {
    it('should successfully override credential with audit log', async () => {
      const mockPerformedBy = 'it-staff-1';
      const mockPreviewSession = {
        type: 'override',
        userId: 'user-1',
        system: 'email',
        proposedCredential: {
          username: 'new.user@company.com',
          password: 'NewPassword456!'
        },
        currentCredential: {
          id: 'cred-1',
          username: 'old.user@company.com',
          password: 'OldPassword123'
        },
        reason: 'User requested specific username format'
      };

      // Mock transaction
      const mockTx = {
        user: {
          findUnique: vi.fn().mockResolvedValue({
            id: 'user-1',
            status: 'active'
          })
        },
        userCredential: {
          update: vi.fn().mockResolvedValue({}),
          create: vi.fn().mockResolvedValue({
            id: 'new-cred-1',
            userId: 'user-1',
            system: 'email',
            username: 'new.user@company.com',
            password: 'NewPassword456!'
          })
        },
        credentialVersion: {
          create: vi.fn().mockResolvedValue({
            id: 'version-1'
          })
        },
        auditLog: {
          create: vi.fn().mockResolvedValue({})
        }
      };

      // Mock prisma transaction
      const mockPrisma = {
        $transaction: vi.fn((fn) => fn(mockTx))
      };
      vi.mock('../../../apps/api/src/shared/db/prisma.js', () => ({
        prisma: mockPrisma
      }));

      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        status: 'active'
      });
      repo.deactivateUserCredential.mockResolvedValue({});
      repo.createUserCredential.mockResolvedValue({
        id: 'new-cred-1',
        userId: 'user-1',
        system: 'email',
        username: 'new.user@company.com',
        password: 'NewPassword456!'
      });
      repo.createCredentialVersion.mockResolvedValue({
        id: 'version-1'
      });
      repo.deletePreviewSession.mockResolvedValue(true);

      const result = await confirmCredentialOverride(mockPerformedBy, mockPreviewSession);

      expect(result).toHaveProperty('credentialId');
      expect(result).toHaveProperty('historyVersionId');
      expect(result.system).toBe('email');
      expect(result.overriddenBy.id).toBe('it-staff-1');
    });

    it('should throw DisabledUserError when user becomes disabled during confirmation', async () => {
      repo.getUserById.mockResolvedValue({
        id: 'user-1',
        status: 'disabled'
      });

      const mockPreviewSession = {
        type: 'override',
        userId: 'user-1',
        system: 'email'
      };

      await expect(
        confirmCredentialOverride('it-staff-1', mockPreviewSession)
      ).rejects.toThrow(DisabledUserError);
    });
  });
});