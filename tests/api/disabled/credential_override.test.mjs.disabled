import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
import { createTestServer } from '../test-utils.js';

// Integration tests for Credential Override API endpoints
// These tests verify the complete flow from API to database

describe('Credential Override API Integration', () => {
    let app;
    let testUser;
    let itStaffUser;
    let authToken;

    beforeAll(async () => {
        // Setup test server and database
        app = await createTestServer();
        
        // Create test users
        testUser = await app.prisma.user.create({
            data: {
                username: 'test.user@company.com',
                status: 'active',
                role: 'requester'
            }
        });
        
        itStaffUser = await app.prisma.user.create({
            data: {
                username: 'it.staff@company.com',
                status: 'active',
                role: 'it'
            }
        });
    });

    afterAll(async () => {
        // Cleanup
        await app.prisma.userCredential.deleteMany();
        await app.prisma.credentialVersion.deleteMany();
        await app.prisma.user.deleteMany();
        await app.close();
    });

    beforeEach(async () => {
        // Clear credentials before each test
        await app.prisma.userCredential.deleteMany();
        await app.prisma.credentialVersion.deleteMany();
    });

    describe('POST /api/v1/credential-templates/users/:userId/:system/override/preview', () => {
        it('should return 403 for non-IT users', async () => {
            const regularUser = await app.prisma.user.create({
                data: {
                    username: 'regular@company.com',
                    status: 'active',
                    role: 'requester'
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Test reason for override'
                },
                cookies: {
                    token: await app.generateAuthToken(regularUser)
                }
            });

            expect(response.statusCode).toBe(403);
            const body = JSON.parse(response.body);
            expect(body.title).toBe('Forbidden');
        });

        it('should return 404 when user does not exist', async () => {
            const response = await app.inject({
                method: 'POST',
                url: '/api/v1/credential-templates/users/non-existent-id/email/override/preview',
                payload: {
                    username: 'new@company.com',
                    reason: 'Test reason for override'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(404);
            const body = JSON.parse(response.body);
            expect(body.type).toBe('/problems/user-not-found');
        });

        it('should return 403 when user is disabled', async () => {
            const disabledUser = await app.prisma.user.create({
                data: {
                    username: 'disabled@company.com',
                    status: 'disabled',
                    role: 'requester'
                }
            });

            // Create a credential for the disabled user
            await app.prisma.userCredential.create({
                data: {
                    userId: disabledUser.id,
                    system: 'email',
                    username: 'disabled@company.com',
                    password: 'TestPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${disabledUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Test reason for override'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(403);
            const body = JSON.parse(response.body);
            expect(body.type).toBe('/problems/disabled-user');
        });

        it('should return 404 when no active credential exists for system', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/vpn/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Test reason for override'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(404);
            const body = JSON.parse(response.body);
            expect(body.type).toBe('/problems/no-active-credential');
        });

        it('should return 400 when reason is too short', async () => {
            // Create a credential for the test user
            await app.prisma.userCredential.create({
                data: {
                    userId: testUser.id,
                    system: 'email',
                    username: 'test@company.com',
                    password: 'TestPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Short' // Less than 10 characters
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(400);
            const body = JSON.parse(response.body);
            expect(body.title).toBe('Invalid Input');
        });

        it('should return 400 when neither username nor password provided', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    reason: 'Test reason for override'
                    // No username or password
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(400);
            const body = JSON.parse(response.body);
            expect(body.detail).toContain('At least one of username or password');
        });

        it('should successfully preview username override', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new.username@company.com',
                    reason: 'User requested specific username format'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(200);
            const body = JSON.parse(response.body);
            expect(body.data).toHaveProperty('previewToken');
            expect(body.data.changes.usernameChanged).toBe(true);
            expect(body.data.changes.passwordChanged).toBe(false);
            expect(body.data.currentCredential.username).toBe('test@company.com');
            expect(body.data.proposedCredential.username).toBe('new.username@company.com');
        });

        it('should successfully preview password override', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    password: 'NewPassword456!',
                    reason: 'Security policy requires password change'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(200);
            const body = JSON.parse(response.body);
            expect(body.data.changes.usernameChanged).toBe(false);
            expect(body.data.changes.passwordChanged).toBe(true);
        });

        it('should successfully preview both username and password override', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new.username@company.com',
                    password: 'NewPassword456!',
                    reason: 'Complete credential reset for security'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(200);
            const body = JSON.parse(response.body);
            expect(body.data.changes.usernameChanged).toBe(true);
            expect(body.data.changes.passwordChanged).toBe(true);
            expect(body.data).toHaveProperty('previewToken');
            expect(body.data).toHaveProperty('expiresAt');
        });
    });

    describe('POST /api/v1/credential-templates/users/:userId/:system/override/confirm', () => {
        it('should return 403 for non-IT users', async () => {
            const regularUser = await app.prisma.user.create({
                data: {
                    username: 'regular2@company.com',
                    status: 'active',
                    role: 'requester'
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/confirm`,
                payload: {
                    previewToken: 'valid-token',
                    confirmed: true
                },
                cookies: {
                    token: await app.generateAuthToken(regularUser)
                }
            });

            expect(response.statusCode).toBe(403);
        });

        it('should return 400 when confirmation is not explicit', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/confirm`,
                payload: {
                    previewToken: 'some-token',
                    confirmed: false // Not explicitly confirmed
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(400);
            const body = JSON.parse(response.body);
            expect(body.type).toBe('/problems/confirmation-required');
        });

        it('should return 400 when preview token is invalid or expired', async () => {
            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/confirm`,
                payload: {
                    previewToken: 'invalid-token',
                    confirmed: true
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(response.statusCode).toBe(400);
            const body = JSON.parse(response.body);
            expect(body.type).toBe('/problems/invalid-preview-token');
        });

        it('should successfully confirm override and create audit log', async () => {
            // Create initial credential
            const initialCredential = await app.prisma.userCredential.create({
                data: {
                    userId: testUser.id,
                    system: 'email',
                    username: 'old@company.com',
                    password: 'OldPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            // Get preview token
            const previewResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    password: 'NewPass456',
                    reason: 'Complete credential reset'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            const previewBody = JSON.parse(previewResponse.body);
            const previewToken = previewBody.data.previewToken;

            // Confirm override
            const confirmResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/confirm`,
                payload: {
                    previewToken,
                    confirmed: true
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(confirmResponse.statusCode).toBe(201);
            const confirmBody = JSON.parse(confirmResponse.body);
            expect(confirmBody.data).toHaveProperty('credentialId');
            expect(confirmBody.data.system).toBe('email');
            expect(confirmBody.data).toHaveProperty('overriddenAt');
            expect(confirmBody.data.overriddenBy.id).toBe(itStaffUser.id);
            expect(confirmBody.data).toHaveProperty('historyVersionId');

            // Verify old credential is deactivated
            const oldCredential = await app.prisma.userCredential.findUnique({
                where: { id: initialCredential.id }
            });
            expect(oldCredential.isActive).toBe(false);

            // Verify new credential is created and active
            const newCredential = await app.prisma.userCredential.findUnique({
                where: { id: confirmBody.data.credentialId }
            });
            expect(newCredential.isActive).toBe(true);
            expect(newCredential.username).toBe('new@company.com');
            expect(newCredential.password).toBe('NewPass456');

            // Verify history entry created
            const historyEntry = await app.prisma.credentialVersion.findUnique({
                where: { id: confirmBody.data.historyVersionId }
            });
            expect(historyEntry).toBeTruthy();
            expect(historyEntry.reason).toBe('override');
            expect(historyEntry.createdBy).toBe(itStaffUser.id);

            // Verify audit log created
            const auditLog = await app.prisma.auditLog.findFirst({
                where: {
                    action: 'credentials.override',
                    entityId: confirmBody.data.credentialId
                }
            });
            expect(auditLog).toBeTruthy();
            expect(auditLog.actorUserId).toBe(itStaffUser.id);
            expect(auditLog.metadata).toMatchObject({
                targetUserId: testUser.id,
                system: 'email',
                usernameChanged: true,
                passwordChanged: true
            });
        });

        it('should successfully perform partial override (username only)', async () => {
            // Create initial credential
            await app.prisma.userCredential.create({
                data: {
                    userId: testUser.id,
                    system: 'vpn',
                    username: 'vpn.user@company.com',
                    password: 'VpnPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            // Get preview token for username-only override
            const previewResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/vpn/override/preview`,
                payload: {
                    username: 'new.vpn.user@company.com',
                    reason: 'Username format change requested'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            const previewBody = JSON.parse(previewResponse.body);
            const previewToken = previewBody.data.previewToken;

            // Confirm override
            const confirmResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/vpn/override/confirm`,
                payload: {
                    previewToken,
                    confirmed: true
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(confirmResponse.statusCode).toBe(201);
            const confirmBody = JSON.parse(confirmResponse.body);
            expect(confirmBody.data.changes.usernameChanged).toBe(true);
            expect(confirmBody.data.changes.passwordChanged).toBe(false);

            // Verify new credential retains old password
            const newCredential = await app.prisma.userCredential.findUnique({
                where: { id: confirmBody.data.credentialId }
            });
            expect(newCredential.username).toBe('new.vpn.user@company.com');
            expect(newCredential.password).toBe('VpnPass123'); // Unchanged
        });

        it('should block override if user becomes disabled between preview and confirm', async () => {
            // Create credential
            await app.prisma.userCredential.create({
                data: {
                    userId: testUser.id,
                    system: 'email',
                    username: 'test@company.com',
                    password: 'TestPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            // Get preview
            const previewResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Testing disabled user guardrail'
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            const previewBody = JSON.parse(previewResponse.body);
            const previewToken = previewBody.data.previewToken;

            // Disable the user
            await app.prisma.user.update({
                where: { id: testUser.id },
                data: { status: 'disabled' }
            });

            // Try to confirm - should fail
            const confirmResponse = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/confirm`,
                payload: {
                    previewToken,
                    confirmed: true
                },
                cookies: {
                    token: await app.generateAuthToken(itStaffUser)
                }
            });

            expect(confirmResponse.statusCode).toBe(403);
            const body = JSON.parse(confirmResponse.body);
            expect(body.type).toBe('/problems/disabled-user');
        });
    });

    describe('RBAC Access Control', () => {
        it('should allow IT role to access override endpoints', async () => {
            const itUser = await app.prisma.user.create({
                data: {
                    username: 'it.test@company.com',
                    status: 'active',
                    role: 'it'
                }
            });

            await app.prisma.userCredential.create({
                data: {
                    userId: testUser.id,
                    system: 'email',
                    username: 'test@company.com',
                    password: 'TestPass123',
                    templateVersion: 1,
                    generatedBy: itStaffUser.id
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Testing RBAC for IT role'
                },
                cookies: {
                    token: await app.generateAuthToken(itUser)
                }
            });

            expect(response.statusCode).toBe(200);
        });

        it('should allow admin role to access override endpoints', async () => {
            const adminUser = await app.prisma.user.create({
                data: {
                    username: 'admin.test@company.com',
                    status: 'active',
                    role: 'admin'
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Testing RBAC for admin role'
                },
                cookies: {
                    token: await app.generateAuthToken(adminUser)
                }
            });

            expect(response.statusCode).toBe(200);
        });

        it('should allow head_it role to access override endpoints', async () => {
            const headItUser = await app.prisma.user.create({
                data: {
                    username: 'headit.test@company.com',
                    status: 'active',
                    role: 'head_it'
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Testing RBAC for head_it role'
                },
                cookies: {
                    token: await app.generateAuthToken(headItUser)
                }
            });

            expect(response.statusCode).toBe(200);
        });

        it('should deny requester role access to override endpoints', async () => {
            const requesterUser = await app.prisma.user.create({
                data: {
                    username: 'requester.test@company.com',
                    status: 'active',
                    role: 'requester'
                }
            });

            const response = await app.inject({
                method: 'POST',
                url: `/api/v1/credential-templates/users/${testUser.id}/email/override/preview`,
                payload: {
                    username: 'new@company.com',
                    reason: 'Testing RBAC for requester role'
                },
                cookies: {
                    token: await app.generateAuthToken(requesterUser)
                }
            });

            expect(response.statusCode).toBe(403);
        });
    });
});