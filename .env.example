# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=it_hub
MYSQL_USER=it_hub
MYSQL_PASSWORD=change-me

# API
API_PORT=3001
DATABASE_URL="mysql://it_hub:change-me@localhost:3306/it_hub"

# Auth / LDAP
LDAP_URL="ldaps://ldap.example.com:636"
LDAP_BASE_DN="dc=example,dc=com"
LDAP_BIND_DN="cn=bind-user,dc=example,dc=com"
LDAP_BIND_PASSWORD="change-me"
LDAP_USER_FILTER="(uid={{username}})"
LDAP_SYNC_FILTER="(objectClass=person)"
LDAP_SYNC_ATTRIBUTES="uid,cn,givenName,sn,mail,employeeNumber,department,title,telephoneNumber,birthDate"
LDAP_SYNC_USERNAME_ATTRIBUTE="uid"
LDAP_SYNC_PAGE_SIZE="500"
LDAP_USE_STARTTLS=false
LDAP_TLS_CA_PATH=""
LDAP_REJECT_UNAUTHORIZED=true
JWT_SECRET="replace-with-long-secret"
JWT_ISSUER="it-hub"
JWT_AUDIENCE="it-hub-web"
JWT_EXPIRES_IN="12h"
# Use "__Host-it-hub-session" only when serving over HTTPS.
AUTH_COOKIE_NAME="it-hub-session"
AUTH_COOKIE_SECURE=true
CORS_ORIGIN="http://localhost:5173"

# Web
VITE_API_BASE_URL="http://localhost:3001"
